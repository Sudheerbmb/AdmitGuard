{
  "manifest_version": 3,
  "name": "AdmitGuard",
  "version": "1.0",
  "description": "Admission Data Validation & Compliance System",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "436650604205-g79pklsqa1k192nqn6gfdepkn4c1k31v.apps.googleusercontent.com",
    "scopes": [
      "email",
      "profile",
      "openid"
    ]
  },
  "host_permissions": [
    "https://*.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "rules.json",
        "audit.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}